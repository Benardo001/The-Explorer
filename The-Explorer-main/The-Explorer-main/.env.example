# Example environment variables for coastexplorer
# Copy to .env and fill values (DO NOT commit .env to source control)

# Django secret (keep secret in production)
DJANGO_SECRET_KEY=your-secret-key

# Debug mode
DJANGO_DEBUG=True

# Email settings
# For development, you can use console backend which prints emails to the console
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@coastexplorer.local

# To use SMTP in production, set these (example values)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-smtp-username
# EMAIL_HOST_PASSWORD=your-smtp-password
# EMAIL_USE_TLS=True

# Optional fallback recipient (used by contact view if ADMINS not set)
# EMAIL_HOST_USER=admin@example.com

# ADMINS can be set in Django settings as a list of tuples. Example in .env processing:
# ADMINS='[("Admin Name","admin@example.com")]'

# Database (example for sqlite)
DATABASE_URL=sqlite:///db.sqlite3
